    "sgmf-scripts": "^3.0.0"
  },
  "browserslist": [
    "last 2 versions",
    "ie >= 10"
  ],
  "packageName": "int_eshopworld_sfra",
  "paths": {
    "base": "../storefront-reference-architecture/cartridges/app_storefront_base",
    "base_ext": "cartridges/int_eshopworld_sfra"
  },
  "babel": {
    "presets": [
      "env"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint"
    }
  }
}