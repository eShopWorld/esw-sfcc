    "@wdio/selenium-standalone-service": "^7.31.1",
    "allure-commandline": "^2.13.0",
    "axios": "^1.7.7",
    "babel-core": "^6.26.3",
    "babel-eslint": "^8.2.6",
    "babel-loader": "^8.0.6",
    "babel-plugin-istanbul": "^6.1.1",
    "babel-preset-env": "^1.7.0",
    "chai": "^3.5.0",
    "chai-subset": "^1.6.0",
    "chalk": "^1.1.3",
    "cheerio": "0.22.0",
    "cldr-data": "^36.0.1",
