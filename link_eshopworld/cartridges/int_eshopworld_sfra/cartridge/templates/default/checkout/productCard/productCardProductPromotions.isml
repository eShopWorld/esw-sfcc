<isif condition="${lineItem.appliedPromotions}">
    <isloop items="${lineItem.appliedPromotions}" var="appliedPromotion">
        <div class="esw-promotion liuuid-${lineItem.UUID} promo-id-${appliedPromotion.promotionID}">
            <isprint value="${appliedPromotion.callOutMsg}" encoding="off" />
        </div>
    </isloop>
</isif>
